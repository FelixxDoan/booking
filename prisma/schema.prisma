generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  STUDENT
  TUTOR
  ADMIN
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum ServiceLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum ServiceMode {
  ONLINE
  OFFLINE
  HYBRID
}

enum Weekday {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum BookingStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum BookingSource {
  STUDENT
  ADMIN
}

model User {
  id           Int        @id @default(autoincrement())
  fullName     String
  email        String     @unique
  passwordHash String
  role         UserRole   @default(STUDENT)
  status       UserStatus @default(ACTIVE)

  tutorProfile TutorProfile?

  blockedSlotsAsTutor BlockedSlot[] @relation("TutorBlockedSlots")
  blockedSlotsCreated BlockedSlot[] @relation("BlockedSlotCreator")

  studentBookings      Booking[]              @relation("StudentBookings")
  tutorBookings        Booking[]              @relation("TutorBookings")
  bookingStatusChanges BookingStatusHistory[] @relation("BookingStatusChanges")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Service {
  id              String       @id @default(uuid())
  code            String       @unique
  name            String
  subject         String
  description     String?
  durationMinutes Int
  price           Decimal      @db.Decimal(10, 2)
  level           ServiceLevel
  mode            ServiceMode
  isActive        Boolean      @default(true)

  bookings        Booking[]

  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
}

model TutorProfile {
  id                String   @id @default(uuid())
  userId            Int      @unique
  headline          String?
  bio               String?
  subjects          String[]
  yearsOfExperience Int?
  teachingModes     String[]
  isActive          Boolean  @default(true)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WorkingHours {
  id        String  @id @default(uuid())
  weekday   Weekday @unique
  startTime String
  endTime   String
  timezone  String  @default("Asia/Ho_Chi_Minh")
  isActive  Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BlockedSlot {
  id String @id @default(uuid())

  tutorId Int?
  tutor   User? @relation("TutorBlockedSlots", fields: [tutorId], references: [id])

  date      DateTime
  startTime String?
  endTime   String?

  reason String?

  createdBy Int?
  creator   User? @relation("BlockedSlotCreator", fields: [createdBy], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([date])
  @@index([tutorId, date])
  @@index([createdBy])
}

model Booking {
  id   String @id @default(uuid())
  code String @unique

  studentId Int
  tutorId   Int?
  serviceId String

  bookingDate DateTime
  startTime   String
  endTime     String

  status BookingStatus @default(PENDING)
  source BookingSource @default(STUDENT)

  studentNote  String?
  internalNote String?
  cancelReason String?
  cancelledAt  DateTime?

  student User     @relation("StudentBookings", fields: [studentId], references: [id])
  tutor   User?    @relation("TutorBookings", fields: [tutorId], references: [id])
  service Service  @relation(fields: [serviceId], references: [id])

  statusHistory BookingStatusHistory[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([bookingDate])
  @@index([studentId])
  @@index([tutorId])
  @@index([serviceId])
  @@index([status])
  @@index([bookingDate, startTime, endTime])
  @@index([tutorId, bookingDate])
  @@index([tutorId, bookingDate, status])
}

model BookingStatusHistory {
  id String @id @default(uuid())

  bookingId   String
  changedById Int?

  fromStatus BookingStatus?
  toStatus   BookingStatus
  note       String?

  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  changedBy User?   @relation("BookingStatusChanges", fields: [changedById], references: [id])

  createdAt DateTime @default(now())

  @@index([bookingId])
  @@index([changedById])
  @@index([toStatus])
  @@index([createdAt])
}