{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "rootDir": "./src",
    "outDir": "./dist",

    "paths": {
      "#generated/*": ["./src/generated/prisma/*"],
      "@modules/*": ["./src/modules/*"],
      "@common/*": ["./src/common/*"],
      "@lib/*": ["./src/lib/*"],
      "@config/*": ["./src/config/*"]
    },

    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,

    "resolveJsonModule": true,
    "sourceMap": true
  },

  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
